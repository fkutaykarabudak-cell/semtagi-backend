// This is empty
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ==========================================
// KULLANICI TABLOLARI
// ==========================================

enum UserRole {
  USER
  ADMIN
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  name           String?
  phone          String?
  googleId       String?   @unique
  emailVerified  Boolean   @default(false)
  verifyCode     String?
  verifyCodeExp  DateTime?
  role           UserRole  @default(USER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  addresses      UserAddress[]
  orders         Order[]
  reviews        Review[]
  notifications  Notification[]

  @@map("users")
}

model UserAddress {
  id          String   @id @default(uuid())
  userId      String
  title       String   // Ev, İş, vb.
  fullAddress String
  district    String?  // İlçe
  city        String?  // Şehir
  latitude    Float?
  longitude   Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("user_addresses")
}

// ==========================================
// RESTORAN TABLOLARI
// ==========================================

model Restaurant {
  id              String   @id @default(uuid())
  name            String
  description     String?
  phone           String
  email           String
  taxNumber       String?
  address         String
  district        String?
  city            String?
  latitude        Float?
  longitude       Float?
  logoUrl         String?
  coverImageUrl   String?
  minOrderAmount  Float    @default(0)
  deliveryInfo    String?  // "Kendi kuryemiz ile teslim", "Gel al", vb.
  isApproved      Boolean  @default(false)
  isActive        Boolean  @default(true)
  isOpen          Boolean  @default(true)
  rating          Float    @default(0)
  totalReviews    Int      @default(0)
  workingHours    Json?    // { "monday": { "open": "09:00", "close": "22:00" }, ... }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users      RestaurantUser[]
  categories Category[]
  products   Product[]
  orders     Order[]
  reviews    Review[]

  @@map("restaurants")
}

model RestaurantUser {
  id           String   @id @default(uuid())
  restaurantId String
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("OWNER") // OWNER, MANAGER, STAFF
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("restaurant_users")
}

// ==========================================
// MENÜ TABLOLARI
// ==========================================

model Category {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  products   Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(uuid())
  categoryId    String
  restaurantId  String
  name          String
  description   String?
  price         Float
  discountPrice Float?   // İndirimli fiyat (null ise indirim yok)
  imageUrl      String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("products")
}

// ==========================================
// SİPARİŞ TABLOLARI
// ==========================================

enum OrderStatus {
  PENDING      // Bekliyor
  ACCEPTED     // Kabul edildi
  PREPARING    // Hazırlanıyor
  ON_THE_WAY   // Yola çıktı
  DELIVERED    // Teslim edildi
  CANCELLED    // İptal edildi
}

enum PaymentMethod {
  CASH          // Nakit
  CREDIT_CARD   // Banka kartı
  MEAL_CARD     // Yemek kartı
}

enum DeliveryType {
  DELIVERY  // Kurye ile teslimat
  PICKUP    // Gel al
}

model Order {
  id            String        @id @default(uuid())
  orderNumber   String        @unique // SMA-20260313-001 gibi
  userId        String
  restaurantId  String
  addressId     String?
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  mealCardBrand String?       // Sodexo, Multinet, Ticket, Edenred
  deliveryType  DeliveryType  @default(DELIVERY)
  totalAmount   Float
  note          String?
  cancelReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user       User         @relation(fields: [userId], references: [id])
  restaurant Restaurant   @relation(fields: [restaurantId], references: [id])
  address    UserAddress? @relation(fields: [addressId], references: [id])
  items      OrderItem[]

  @@map("orders")
}

model OrderItem {
  id          String @id @default(uuid())
  orderId     String
  productId   String?
  productName String  // Ürün silinse bile isim kalır
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  note        String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

// ==========================================
// PUANLAMA & BİLDİRİM
// ==========================================

model Review {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  orderId      String   @unique
  rating       Int      // 1-5
  comment      String?
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("reviews")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   // ORDER_STATUS, PROMOTION, REVIEW_REQUEST
  data      Json?    // Ek veri (orderId vb.)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ==========================================
// ADMIN
// ==========================================

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  @@map("admin_users")
}
